# WhatsApp Bot Configuration

# Groq API Key for AI chat feature
GROQ_API_KEY=your_groq_api_key_here

# Bot command prefix (default: .)
BOT_PREFIX=.

# Owner's WhatsApp number (with country code, no + or spaces)
# Example: 1234567890
OWNER_NUMBER=

# Enable/disable features by default (1 = enabled, 0 = disabled)
DEFAULT_ANTI_DELETE=1
DEFAULT_VIEWONCE_SAVE=1
DEFAULT_AUTO_VIEW_STATUS=0
DEFAULT_AUTO_REACT_STATUS=0
